# Database
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/novamart?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@novamart.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin Secret (for creating admin users)
ADMIN_SECRET=admin_secret_key_change_this
